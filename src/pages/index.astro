---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="calóh — design studio"
  description="A one-person studio crafting digital products that feel warm, work quietly, and respect your data."
>
  <main>
    <div class="container">

      <section class="hero">
        <h1 class="hero-heading">
          Products that feel warm,<br />work quietly.
        </h1>
        <p class="hero-body">
          A one-person studio crafting digital products that feel warm, work quietly,
          and respect your data. Led by{' '}
          <a
            href="https://oxejoq.eu"
            target="_blank"
            rel="noopener noreferrer"
          >Quino Terrasa</a>.
        </p>
      </section>

      <section class="services" aria-label="Services">
        <ul class="services-list">
          <li>Full-stack development</li>
          <li>Product engineering</li>
          <li>AI integration</li>
        </ul>
      </section>

      <div class="brand-image-block">
        <img
          src="/assets/brand.jpeg"
          alt="calóh studio mark"
          width="1280"
          height="1280"
          loading="lazy"
        />
      </div>

    </div>
  </main>
</Layout>
